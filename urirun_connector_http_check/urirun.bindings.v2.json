{
  "version": "urirun.bindings.v2",
  "bindings": {
    "httpcheck://host/http/query/status": {
      "uri": "httpcheck://host/http/query/status",
      "kind": "command",
      "adapter": "argv-template",
      "argv": [
        "urirun-http-check",
        "status",
        "{url}",
        "--expect-status",
        "{expectStatus}",
        "--timeout",
        "{timeout}"
      ],
      "inputSchema": {
        "type": "object",
        "required": [
          "url"
        ],
        "properties": {
          "url": {
            "type": "string"
          },
          "expectStatus": {
            "type": "integer",
            "default": 200
          },
          "timeout": {
            "type": "number",
            "default": 10
          }
        },
        "additionalProperties": false
      },
      "meta": {
        "label": "Check HTTP status",
        "connector": "http-check"
      }
    }
  }
}
